{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS"
    ],
    "requireConfirmation": [
      "Write",
      "Edit",
      "Bash"
    ]
  },
  "theme": "default",
  "plugins": [
    "plugins/engineering-std",
    "plugins/global"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}